# Admin app environment variables — names only, never real secrets in this file.
# Copy to .env for local development; set the real values in Vercel project
# settings for Preview and Production (see VERCEL_SETUP.md).

# ── Browser-safe (Vite exposes anything prefixed VITE_ to the client bundle) ──
# Same Supabase project as the public site. The anon key is safe to expose —
# it has no table access until RLS explicitly grants it, and after Phase 1
# migrations, "authenticated" has zero direct read access to bookings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Server-only (Vercel serverless functions under admin/api/) ───────────────
# NEVER prefix with VITE_. NEVER import from admin/src/. NEVER log the value.
# This is the Supabase service-role key — it bypasses RLS entirely.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of the deployed admin app, used to build Supabase password-reset
# redirect links (e.g. http://localhost:5174 in development,
# https://admin.vveclean.co.uk in production).
ADMIN_SITE_URL=

# Comma-separated list of origins allowed to call admin/api/* in production
# (e.g. https://admin.vveclean.co.uk). Development origins are allowed
# automatically when NODE_ENV/VERCEL_ENV is not "production" — see
# admin/api/_lib/cors.js — do not add localhost here for production use.
ADMIN_ALLOWED_ORIGINS=
